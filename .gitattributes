* text=auto eol=lf

*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.svg filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.woff2 filter=lfs diff=lfs merge=lfs -text
*.ttf filter=lfs diff=lfs merge=lfs -text

# Keep real Font Awesome woff2 binaries here as a non-LFS fallback for
# environments without git-lfs. scripts/build-dist.sh restores these into
# src/assets/fonts/ before vite builds, so the packaged dist ships valid fonts.
patches/fonts/*.woff2 -filter -diff -merge binary
patches/fonts/*.ttf -filter -diff -merge binary

/.github export-ignore
/.husky export-ignore
/docs export-ignore
.gitattributes export-ignore
.gitignore export-ignore
